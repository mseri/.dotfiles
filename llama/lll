#!/usr/bin/env python3
"""
lll - Minimal llama-server/llama-cli wrapper for models.ini

Usage:
    lll              - Start llama-server with models.ini preset
    lll run <alias>  - Run a specific model with llama-cli
    lll dry <alias>  - Show the command for a specific model
"""

import argparse
import configparser
import platform
import subprocess
import sys
from pathlib import Path

INI_FILE = Path.home() / ".dotfiles" / "llama" / "models.ini"


def is_apple_silicon():
    """Return True if running on Apple Silicon (ARM Mac)."""
    return sys.platform == "darwin" and platform.machine() == "arm64"


def resolve_gpu(args):
    """Resolve whether GPU offloading should be enabled.

    On Apple Silicon, GPU is on by default; --gpu disables it.
    On Intel (or non-Mac), GPU is off by default; --gpu enables it.
    """
    if is_apple_silicon():
        return not args.gpu
    return args.gpu


def load_ini():
    """Load models.ini, strip version line, and return parsed config."""
    if not INI_FILE.exists():
        print(f"Error: {INI_FILE} not found.", file=sys.stderr)
        sys.exit(1)

    with open(INI_FILE, "r") as f:
        lines = f.readlines()

    # version is required for llama-server, but ConfigParser fails with it
    lines = [line for line in lines if not line.strip().startswith("version =")]
    content = "".join(lines)

    config = configparser.ConfigParser()
    config.read_string(content)
    return config


def get_aliases(config):
    """Extract alias -> model mappings from config."""
    aliases = {}
    for section in config.sections():
        if section == "*":
            continue
        # Section headers are now the aliases
        aliases[section] = section
    return aliases


def build_cli_command(config, model_key, args):
    """Build llama-cli command with parameters from config section."""
    if model_key not in config:
        print(f"Error: model {model_key} not found in {INI_FILE}.", file=sys.stderr)
        sys.exit(1)

    cmd = ["llama-cli"]
    params = config[model_key]

    for key, value in params.items():
        cmd.extend([f"--{key}", str(value)])

    cmd.extend(["-ngl", "99" if resolve_gpu(args) else "0"])

    if not args.vision:
      cmd.extend(["--no-mmproj"])

    if args.fa:
      cmd.extend(["--fa", "on"])

    return cmd


def run_server(args):
    """Start llama-server with models.ini preset."""
    cmd = ["llama-server", "--models-preset", str(INI_FILE)]

    cmd.extend(["-ngl", "99" if resolve_gpu(args) else "0"])
    if not args.vision:
      cmd.extend(["--no-mmproj"])
    if args.fa:
      cmd.extend(["--fa", "on"])

    try:
        print(f"Calling: {cmd}")
        subprocess.run(cmd, check=True)
    except KeyboardInterrupt:
        print("\nShutting down llama-server...", file=sys.stderr)
        sys.exit(0)
    except subprocess.CalledProcessError as e:
        print(f"Error running llama-server: {e}", file=sys.stderr)
        sys.exit(1)


def run_model(config, aliases, args):
    """Run a specific model using llama-cli."""
    if args.alias not in aliases:
        print(
            f"Error: unknown alias '{args.alias}'.\n"
            f"Available aliases: {', '.join(sorted(aliases))}",
            file=sys.stderr,
        )
        sys.exit(1)

    model_key = aliases[args.alias]
    cmd = build_cli_command(config, model_key, args)

    try:
        subprocess.run(cmd, check=True)
    except KeyboardInterrupt:
        print("\nShutting down llama-cli...", file=sys.stderr)
        sys.exit(0)
    except subprocess.CalledProcessError as e:
        print(f"Error running command: {e}", file=sys.stderr)
        sys.exit(1)


def dry_run(config, aliases, args):
    """Print the command that would be run for a model."""
    if args.alias not in aliases:
        print(
            f"Error: unknown alias '{args.alias}'.\n"
            f"Available aliases: {', '.join(sorted(aliases))}",
            file=sys.stderr,
        )
        sys.exit(1)

    model_key = aliases[args.alias]
    cmd = build_cli_command(config, model_key, args)
    print(" ".join(cmd))


def main():
    config = load_ini()
    aliases = get_aliases(config)

    parser = argparse.ArgumentParser(description="lll - llama-server/llama-cli wrapper")
    parser.add_argument(
        "--vision",
        action="store_true",
        help="Enable vision features (for multimodal models)",
    )
    _apple_silicon = is_apple_silicon()
    parser.add_argument(
      "--gpu",
      action="store_true",
      help="Disable GPU offloading" if _apple_silicon else "Enable GPU offloading",
    )
    parser.add_argument(
      "--fa",
      action="store_true",
      help="Use flash attention",
    )
    subparsers = parser.add_subparsers(dest="command", required=False)

    run_parser = subparsers.add_parser("run", help="Run a model by alias")
    run_parser.add_argument(
        "alias",
        nargs="?",
        help=f"Model alias. Available: {', '.join(sorted(aliases))}",
    )

    dry_parser = subparsers.add_parser("dry", help="Show the command for a model")
    dry_parser.add_argument(
        "alias",
        nargs="?",
        help="Model alias",
    )

    args = parser.parse_args()

    if args.command is None:
        run_server(args)
        return

    if args.command == "run":
        if not args.alias:
            print(f"Available aliases: {', '.join(sorted(aliases))}")
            print("Usage: lll run ALIAS")
            sys.exit(1)
        run_model(config, aliases, args)

    elif args.command == "dry":
        if not args.alias:
            print(f"Available aliases: {', '.join(sorted(aliases))}")
            print("Usage: lll dry ALIAS")
            sys.exit(1)
        dry_run(config, aliases, args)


if __name__ == "__main__":
    main()
